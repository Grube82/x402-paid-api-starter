# ---------------------------------------------------------------------------
# x402-paid-api-starter configuration
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Your wallet address that RECEIVES payments. Public address only — this
# server never holds or needs a private key. Leave blank to run the API with
# payments DISABLED (all routes free) — handy for local development.
PAYEE_EVM_ADDRESS=

# --- Testnet vs mainnet -----------------------------------------------------
# true  = Base Sepolia testnet via the public x402.org facilitator (no auth,
#         no real money). Start here.
# false = Base mainnet (real USDC) via Coinbase's CDP facilitator. Requires
#         the CDP_* credentials below.
X402_TESTNET=true

# --- Mainnet only: Coinbase CDP facilitator credentials ---------------------
# Free tier: 1000 settlements/month. Sign up at https://portal.cdp.coinbase.com
# CDP_API_KEY_SECRET is the base64-encoded Ed25519 private key seed.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# --- Optional: dual-chain (mainnet only) ------------------------------------
# Set a Solana base58 payee address to ALSO accept USDC on Solana mainnet.
# IMPORTANT: pre-fund this address with a tiny USDC amount first so its token
# account exists before the first incoming payment. Leave blank for Base-only.
PAYEE_SOLANA_ADDRESS=

# --- Optional: discovery ----------------------------------------------------
# Your public base URL (e.g. https://api.example.com). Used in the
# /.well-known/x402 discovery manifest. Leave blank to omit absolute URLs.
PUBLIC_BASE_URL=

# --- Optional: settlement ledger --------------------------------------------
# Path to the SQLite file recording every settled payment. Default: payments.db
LEDGER_DB_PATH=payments.db
